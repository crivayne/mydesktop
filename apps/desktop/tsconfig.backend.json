{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "lib/backend",
    "rootDir": "src",
    "types": ["node", "electron"],
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "noEmit": false
  },
  "include": [
    "src/backend/**/*",
    "src/common/**/*"
  ],
  "exclude": ["src/frontend/**/*", "dist"]
}