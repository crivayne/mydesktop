{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "lib",
    "rootDir": "src",
    "types": ["node", "electron" ],
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "noEmit": false,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
  },
  "include": [
    "src/backend/**/*",
    "src/common/**/*"
  ],
  "exclude": [
    "src/frontend/**/*",
    "dist",
    "lib",
    "node_modules"
  ]
}