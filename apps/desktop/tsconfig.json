{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "types": ["vite/client", "node", "electron"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../..//packages/shared-ui/src/*"]
    },
    "noEmit": true,
    "incremental": true
  },
  "include": [
    "index.html",
    "src/frontend/**/*",
    "src/common/**/*",
    "src/types/**/*"
  ],
  "exclude": ["src/backend/**/*", "lib", "dist"]
}